<div class="container py-4" style="max-width: 800px;">
  <%= link_to therapists_path, class: 'btn btn-sm btn-outline-glass mb-3' do %>
    <i class="bi bi-arrow-left me-1"></i> Back to Marketplace
  <% end %>

  <div class="glass-card-static p-4 mb-4">
    <div class="d-flex align-items-start gap-4 mb-4">
      <%= user_avatar(@therapist.user, size: 80, css_class: 'flex-shrink-0') %>
      <div>
        <h2 class="fw-bold mb-1"><%= @therapist.user.full_name %></h2>
        <span class="badge-gradient me-2"><%= @therapist.specialization %></span>
        <span class="badge-glass"><%= @therapist.years_experience %> years experience</span>
        <div class="mt-2">
          <span class="fw-bold" style="color: #F39C12;"><%= @therapist.rating&.round(1) || 'New' %> ⭐</span>
          <span class="ms-3 gradient-text fw-bold" style="font-size: 1.3rem;">$<%= @therapist.hourly_rate&.round(0) %>/hr</span>
        </div>
      </div>
    </div>

    <h5 class="fw-bold mb-2">About</h5>
    <p class="text-muted"><%= @therapist.bio %></p>

    <% if @therapist.certifications.present? %>
      <h5 class="fw-bold mb-2 mt-4">Certifications</h5>
      <p class="text-muted"><%= @therapist.certifications %></p>
    <% end %>
  </div>

  <!-- Booking Form -->
  <div class="glass-card-static p-4">
    <h5 class="fw-bold mb-3"><i class="bi bi-calendar-plus me-2" style="color: #6C63FF;"></i>Book a Session</h5>

    <%= form_with(model: @booking, url: bookings_path(therapist_id: @therapist.id)) do |f| %>
      <div class="row g-3">
        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :scheduled_at, 'Date & Time', class: 'form-label' %>
            <%= f.datetime_local_field :scheduled_at, class: 'form-control', min: Time.current.strftime('%Y-%m-%dT%H:%M') %>
          </div>
        </div>
        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :session_type, 'Session Type', class: 'form-label' %>
            <%= f.select :session_type, [['Video Call', 'video'], ['Voice Call', 'voice'], ['Chat', 'chat']], {}, class: 'form-select' %>
          </div>
        </div>
        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :duration, 'Duration (minutes)', class: 'form-label' %>
            <%= f.select :duration, [[30, 30], [45, 45], [60, 60], [90, 90]], {}, class: 'form-select' %>
          </div>
        </div>
        <div class="col-12">
          <div class="mb-3">
            <%= f.label :notes, 'Notes for the therapist', class: 'form-label' %>
            <%= f.text_area :notes, class: 'form-control', rows: 3, placeholder: "Briefly describe what you'd like to discuss..." %>
          </div>
        </div>
      </div>
      <%= f.submit 'Book Session', class: 'btn btn-gradient btn-lg' %>
    <% end %>
  </div>
</div>
