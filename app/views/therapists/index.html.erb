<div class="container py-4">
  <div class="page-header">
    <h1>👨‍⚕️ Therapist <span class="gradient-text">Marketplace</span></h1>
    <p>Connect with licensed relationship professionals</p>
  </div>

  <!-- Filter -->
  <div class="glass-card-static p-3 mb-4">
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <span class="fw-bold small me-2">Filter by:</span>
      <%= link_to 'All', therapists_path, class: "btn btn-sm #{params[:specialization].blank? ? 'btn-gradient' : 'btn-outline-glass'}" %>
      <% @specializations.each do |spec| %>
        <%= link_to spec, therapists_path(specialization: spec), class: "btn btn-sm #{params[:specialization] == spec ? 'btn-gradient' : 'btn-outline-glass'}" %>
      <% end %>
    </div>
  </div>

  <% if @therapists.any? %>
    <div class="row g-4">
      <% @therapists.each do |profile| %>
        <div class="col-md-6 col-lg-4 animate-fade-in-up">
          <div class="glass-card p-4 h-100">
            <div class="d-flex align-items-start gap-3 mb-3">
              <div style="width: 56px; height: 56px; border-radius: 50%; background: linear-gradient(135deg, #6C63FF, #FF6B9D); display: flex; align-items: center; justify-content: center; font-size: 1.5rem; flex-shrink: 0;">
                👨‍⚕️
              </div>
              <div>
                <h5 class="fw-bold mb-0"><%= profile.user.full_name %></h5>
                <span class="badge-glass"><%= profile.specialization %></span>
              </div>
            </div>

            <p class="text-muted small mb-3"><%= profile.bio.truncate(120) %></p>

            <div class="d-flex justify-content-between align-items-center mb-3">
              <div>
                <span class="text-muted small">Experience:</span>
                <span class="fw-bold small"><%= profile.years_experience %> years</span>
              </div>
              <div>
                <span class="text-muted small">Rating:</span>
                <span class="fw-bold small" style="color: #F39C12;"><%= profile.rating&.round(1) || '—' %> ⭐</span>
              </div>
            </div>

            <div class="d-flex justify-content-between align-items-center">
              <div class="gradient-text fw-bold">$<%= profile.hourly_rate&.round(0) %>/hr</div>
              <%= link_to 'View Profile', therapist_path(profile), class: 'btn btn-sm btn-gradient' %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="glass-card-static p-5">
      <div class="empty-state">
        <div class="empty-icon">👨‍⚕️</div>
        <h3>No therapists found</h3>
        <p>Try selecting a different specialization or check back later.</p>
      </div>
    </div>
  <% end %>
</div>
