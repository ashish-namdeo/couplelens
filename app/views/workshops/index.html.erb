<div class="container py-4">
  <div class="page-header">
    <h1>🎯 Workshops & <span class="gradient-text">Retreats</span></h1>
    <p>Live workshops, therapy retreats, and couple experiences</p>
  </div>

  <% if @workshops.any? %>
    <div class="row g-4">
      <% @workshops.each do |workshop| %>
        <div class="col-md-6 col-lg-4 animate-fade-in-up">
          <div class="glass-card p-4 h-100 d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <span class="badge-gradient"><%= workshop.workshop_type&.titleize %></span>
              <% if workshop.sold_out? %>
                <span class="badge bg-danger">Sold Out</span>
              <% else %>
                <span class="badge bg-success"><%= workshop.spots_remaining %> spots left</span>
              <% end %>
            </div>

            <h5 class="fw-bold"><%= workshop.title %></h5>
            <p class="text-muted small flex-grow-1"><%= workshop.description.truncate(120) %></p>

            <div class="mb-3">
              <div class="text-muted small mb-1"><i class="bi bi-calendar me-1"></i><%= workshop.workshop_date&.strftime('%B %d, %Y at %I:%M %p') %></div>
              <div class="text-muted small mb-1"><i class="bi bi-person me-1"></i><%= workshop.instructor %></div>
              <div class="text-muted small"><i class="bi bi-geo-alt me-1"></i><%= workshop.location %></div>
            </div>

            <div class="d-flex justify-content-between align-items-center">
              <div class="gradient-text fw-bold" style="font-size: 1.3rem;">$<%= workshop.price&.round(0) %></div>
              <% unless workshop.sold_out? %>
                <%= link_to register_workshop_path(workshop), method: :post, class: 'btn btn-sm btn-gradient' do %>
                  <span>Register</span>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="glass-card-static p-5">
      <div class="empty-state">
        <div class="empty-icon">🎯</div>
        <h3>No upcoming workshops</h3>
        <p>New workshops and retreats are added regularly. Check back soon!</p>
      </div>
    </div>
  <% end %>
</div>
