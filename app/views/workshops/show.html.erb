<div class="container py-4" style="max-width: 800px;">
  <%= link_to workshops_path, class: 'btn btn-sm btn-outline-glass mb-3' do %>
    <i class="bi bi-arrow-left me-1"></i> Back
  <% end %>
  <div class="glass-card-static p-4">
    <span class="badge-gradient mb-2 d-inline-block"><%= @workshop.workshop_type&.titleize %></span>
    <h2 class="fw-bold"><%= @workshop.title %></h2>
    <p class="text-muted"><%= @workshop.description %></p>
    <div class="row g-3 my-4">
      <div class="col-md-3 col-6 text-center">
        <div class="text-muted small">Date</div>
        <div class="fw-bold"><%= @workshop.workshop_date&.strftime('%b %d, %Y') %></div>
      </div>
      <div class="col-md-3 col-6 text-center">
        <div class="text-muted small">Instructor</div>
        <div class="fw-bold"><%= @workshop.instructor %></div>
      </div>
      <div class="col-md-3 col-6 text-center">
        <div class="text-muted small">Location</div>
        <div class="fw-bold"><%= @workshop.location %></div>
      </div>
      <div class="col-md-3 col-6 text-center">
        <div class="text-muted small">Price</div>
        <div class="fw-bold gradient-text" style="font-size: 1.3rem;">$<%= @workshop.price&.round(0) %></div>
      </div>
    </div>
    <div class="d-flex justify-content-between align-items-center">
      <span class="text-muted"><%= @workshop.spots_remaining %> of <%= @workshop.capacity %> spots remaining</span>
      <% unless @workshop.sold_out? %>
        <%= link_to register_workshop_path(@workshop), method: :post, class: 'btn btn-gradient btn-lg' do %>
          <span>Register Now</span>
        <% end %>
      <% else %>
        <span class="badge bg-danger">Sold Out</span>
      <% end %>
    </div>
  </div>
</div>
