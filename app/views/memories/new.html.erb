<div class="container py-4" style="max-width: 600px;">
  <div class="page-header">
    <h1>💝 New <span class="gradient-text">Memory</span></h1>
    <p>Capture a special moment</p>
  </div>

  <%= form_with(model: @memory, class: 'animate-fade-in', multipart: true) do |f| %>
    <div class="glass-card-static p-4">
      <div class="mb-3">
        <%= f.label :title, class: 'form-label' %>
        <%= f.text_field :title, class: 'form-control', placeholder: 'Give this memory a title' %>
      </div>

      <div class="mb-3">
        <%= f.label :memory_type, 'Type', class: 'form-label' %>
        <%= f.select :memory_type, Memory::MEMORY_TYPES.map { |t| [t.titleize, t] }, { prompt: 'Select type' }, class: 'form-select' %>
      </div>

      <div class="mb-3">
        <%= f.label :memory_date, 'Date', class: 'form-label' %>
        <%= f.date_field :memory_date, class: 'form-control', value: Date.current %>
      </div>

      <div class="mb-3">
        <%= f.label :description, class: 'form-label' %>
        <%= f.text_area :description, class: 'form-control', rows: 4, placeholder: 'Describe this memory...' %>
      </div>

      <div class="mb-4">
        <%= f.label :photo, 'Photo (optional)', class: 'form-label' %>
        <%= f.file_field :photo, class: 'form-control' %>
      </div>

      <div class="d-flex gap-3">
        <%= f.submit 'Save Memory', class: 'btn btn-gradient btn-lg' %>
        <%= link_to 'Cancel', memories_path, class: 'btn btn-outline-glass btn-lg' %>
      </div>
    </div>
  <% end %>
</div>
