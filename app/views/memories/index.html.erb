<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div class="page-header mb-0">
      <h1>💝 Memory <span class="gradient-text">Timeline</span></h1>
      <p>Your private couple moments</p>
    </div>
    <%= link_to new_memory_path, class: 'btn btn-gradient' do %>
      <span><i class="bi bi-plus-lg me-1"></i> Add Memory</span>
    <% end %>
  </div>

  <% if @memories.any? %>
    <div class="memory-timeline">
      <% @memories.each do |memory| %>
        <div class="timeline-item animate-fade-in-up">
          <div class="glass-card p-4">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <span style="font-size: 1.5rem;" class="me-2"><%= memory.memory_icon %></span>
                <span class="fw-bold"><%= memory.title %></span>
                <span class="badge-glass ms-2"><%= memory.memory_type&.titleize %></span>
              </div>
              <div class="d-flex align-items-center gap-2">
                <small class="text-muted"><%= memory.memory_date.strftime('%B %d, %Y') %></small>
                <%= link_to memory, method: :delete, data: { confirm: 'Remove this memory?' }, class: 'btn btn-sm text-danger' do %>
                  <i class="bi bi-trash"></i>
                <% end %>
              </div>
            </div>
            <% if memory.description.present? %>
              <p class="text-muted mt-2 mb-0"><%= memory.description %></p>
            <% end %>
            <% if memory.photo.attached? %>
              <div class="mt-3">
                <%= image_tag memory.photo, class: 'img-fluid rounded', style: 'max-height: 300px; object-fit: cover;' %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="glass-card-static p-5">
      <div class="empty-state">
        <div class="empty-icon">💝</div>
        <h3>No memories yet</h3>
        <p>Start recording your special moments together. Add milestones, trips, date nights, and more.</p>
        <%= link_to new_memory_path, class: 'btn btn-gradient mt-3' do %>
          <span>Add First Memory</span>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
