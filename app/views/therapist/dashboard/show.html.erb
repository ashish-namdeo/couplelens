<div class="container py-4">
  <div class="page-header">
    <h1>🩺 Therapist <span class="gradient-text">Dashboard</span></h1>
    <p>Welcome back, <%= current_user.full_name %></p>
  </div>

  <!-- Stats Row -->
  <div class="row g-4 mb-4">
    <div class="col-md-3 col-6">
      <div class="stat-card text-center">
        <div class="stat-value gradient-text"><%= @total_sessions %></div>
        <div class="stat-label">Completed Sessions</div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="stat-card text-center">
        <div class="stat-value" style="color: #FF6B9D;"><%= @total_clients %></div>
        <div class="stat-label">Total Clients</div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="stat-card text-center">
        <div class="stat-value" style="color: #2ECC71;">$<%= number_with_delimiter(@total_revenue.to_i) %></div>
        <div class="stat-label">Total Revenue</div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="stat-card text-center">
        <div class="stat-value" style="color: #F39C12;"><%= @pending_bookings %></div>
        <div class="stat-label">Pending Bookings</div>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <!-- Profile Card -->
    <div class="col-md-4">
      <div class="glass-card-static p-4 h-100">
        <h5 class="fw-bold mb-3">👤 My Profile</h5>
        <div class="mb-2">
          <span style="color: #aaa;">Specialization</span><br>
          <span class="badge-glass mt-1"><%= @profile.specialization %></span>
        </div>
        <div class="mb-2 mt-3">
          <span style="color: #aaa;">Experience</span><br>
          <strong><%= @profile.years_experience %> years</strong>
        </div>
        <div class="mb-2 mt-3">
          <span style="color: #aaa;">Hourly Rate</span><br>
          <strong style="color: #2ECC71;">$<%= @profile.hourly_rate.to_i %>/hr</strong>
        </div>
        <div class="mb-2 mt-3">
          <span style="color: #aaa;">Rating</span><br>
          <strong style="color: #F39C12;">⭐ <%= @profile.rating %>/5.0</strong>
        </div>
        <div class="mb-2 mt-3">
          <span style="color: #aaa;">Status</span><br>
          <% if @profile.approved? %>
            <span class="badge bg-success">Approved</span>
          <% elsif @profile.suspended? %>
            <span class="badge bg-danger">Suspended</span>
          <% else %>
            <span class="badge bg-warning text-dark">Pending</span>
          <% end %>
        </div>
        <%= link_to 'Edit Profile', edit_therapist_profile_path, class: 'btn btn-outline-glass btn-sm mt-3' %>
      </div>
    </div>

    <!-- Upcoming Bookings -->
    <div class="col-md-8">
      <div class="glass-card-static p-4 h-100">
        <h5 class="fw-bold mb-3">📅 Upcoming Sessions</h5>
        <% if @upcoming_bookings.any? %>
          <div class="table-responsive">
            <table class="table table-dark-custom">
              <thead>
                <tr>
                  <th>Client</th>
                  <th>Date & Time</th>
                  <th>Type</th>
                  <th>Duration</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% @upcoming_bookings.each do |booking| %>
                  <tr>
                    <td class="fw-bold"><%= booking.user.full_name %></td>
                    <td><%= booking.scheduled_at.strftime('%b %d, %Y at %I:%M %p') %></td>
                    <td><span class="badge-glass"><%= booking.session_type&.capitalize %></span></td>
                    <td><%= booking.duration %> min</td>
                    <td>
                      <% case booking.status %>
                      <% when 'pending' %>
                        <span class="badge bg-warning text-dark">Pending</span>
                      <% when 'confirmed' %>
                        <span class="badge bg-success">Confirmed</span>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="text-center py-4" style="color: #888;">
            <p class="fs-1">📭</p>
            <p>No upcoming sessions yet.</p>
            <p class="small">Clients can book sessions from your therapist profile page.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Past Sessions -->
  <div class="row g-4 mt-1">
    <div class="col-12">
      <div class="glass-card-static p-4">
        <h5 class="fw-bold mb-3">📋 Recent Completed Sessions</h5>
        <% if @past_bookings.any? %>
          <div class="table-responsive">
            <table class="table table-dark-custom">
              <thead>
                <tr>
                  <th>Client</th>
                  <th>Date</th>
                  <th>Type</th>
                  <th>Duration</th>
                  <th>Amount</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% @past_bookings.each do |booking| %>
                  <tr>
                    <td class="fw-bold"><%= booking.user.full_name %></td>
                    <td><%= booking.scheduled_at.strftime('%b %d, %Y') %></td>
                    <td><span class="badge-glass"><%= booking.session_type&.capitalize %></span></td>
                    <td><%= booking.duration %> min</td>
                    <td style="color: #2ECC71;">$<%= booking.amount.to_i %></td>
                    <td>
                      <% case booking.status %>
                      <% when 'completed' %>
                        <span class="badge bg-success">Completed</span>
                      <% when 'cancelled' %>
                        <span class="badge bg-danger">Cancelled</span>
                      <% else %>
                        <span class="badge bg-secondary"><%= booking.status.capitalize %></span>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="text-center py-3" style="color: #888;">
            <p>No completed sessions yet.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
