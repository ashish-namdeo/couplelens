<div class="container py-4" style="max-width: 700px;">
  <div class="page-header">
    <h1>⚖️ New <span class="gradient-text">Mediation Session</span></h1>
    <p>Share your perspective on the conflict</p>
  </div>

  <%= form_with(model: @conflict_session, class: 'animate-fade-in', data: { turbo: false }) do |f| %>
    <div class="glass-card-static p-4">
      <div class="mb-3">
        <label class="form-label">Select Language / भाषा चुनें</label>
        <%= f.select :language, [['English', 'english'], ['हिन्दी (Hindi)', 'hindi']], {}, class: 'form-select', id: 'language-select' %>
      </div>

      <div class="mb-3">
        <%= f.label :partner_name, "Your Partner's Name", class: 'form-label' %>
        <%= f.text_field :partner_name, class: 'form-control', placeholder: 'Enter partner name', id: 'partner-name-field' %>
      </div>

      <div class="mb-3">
        <%= f.label :topic, 'Conflict Topic', class: 'form-label' %>
        <%= f.text_field :topic, class: 'form-control', placeholder: 'e.g., Disagreement about household responsibilities', id: 'topic-field' %>
      </div>

      <div class="mb-4">
        <%= f.label :user_perspective, 'Your Perspective (Optional if screenshots added)', class: 'form-label' %>
        <%= f.text_area :user_perspective, class: 'form-control', rows: 6, placeholder: "Share your side of the story. Be honest and specific about how you feel and what happened...", id: 'perspective-field' %>
        <div class="form-text" style="color: #aaa;">Your perspective will be analyzed alongside your partner's for unbiased mediation.</div>
      </div>

      <!-- Chat Screenshots Upload -->
      <div class="mb-4">
        <label class="form-label"><i class="bi bi-image me-1"></i> Chat Screenshots (Optional)</label>
        <%= f.file_field :chat_screenshots, multiple: true, accept: 'image/*', class: 'form-control', id: 'screenshot-upload' %>
        <div class="form-text" style="color: #aaa;">Upload screenshots from WhatsApp, iMessage or any chat app. AI will analyze the conversation for conflict patterns.</div>
        <div id="screenshot-preview" class="d-flex flex-wrap gap-2 mt-2"></div>
      </div>

      <div class="d-flex gap-3">
        <%= f.submit 'Submit Perspective', class: 'btn btn-gradient btn-lg' %>
        <%= link_to 'Cancel', conflict_sessions_path, class: 'btn btn-outline-glass btn-lg' %>
      </div>
    </div>
  <% end %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const langSelect = document.getElementById('language-select');
    const partnerField = document.getElementById('partner-name-field');
    const topicField = document.getElementById('topic-field');
    const perspectiveField = document.getElementById('perspective-field');

    langSelect.addEventListener('change', function() {
      if (this.value === 'hindi') {
        partnerField.placeholder = 'साथी का नाम दर्ज करें';
        topicField.placeholder = 'उदा., घरेलू जिम्मेदारियों को लेकर असहमति';
        perspectiveField.placeholder = 'अपनी बात साझा करें। ईमानदारी से बताएं कि आपको कैसा लगा और क्या हुआ...';
      } else {
        partnerField.placeholder = 'Enter partner name';
        topicField.placeholder = 'e.g., Disagreement about household responsibilities';
        perspectiveField.placeholder = "Share your side of the story. Be honest and specific about how you feel and what happened...";
      }
    });

    // Screenshot preview
    const screenshotInput = document.getElementById('screenshot-upload');
    const previewContainer = document.getElementById('screenshot-preview');
    if (screenshotInput) {
      screenshotInput.addEventListener('change', function() {
        previewContainer.innerHTML = '';
        Array.from(this.files).forEach(function(file) {
          const reader = new FileReader();
          reader.onload = function(e) {
            const img = document.createElement('img');
            img.src = e.target.result;
            img.style.cssText = 'width: 100px; height: 100px; object-fit: cover; border-radius: 8px; border: 2px solid rgba(108, 99, 255, 0.3);';
            previewContainer.appendChild(img);
          };
          reader.readAsDataURL(file);
        });
      });
    }
  });
</script>
