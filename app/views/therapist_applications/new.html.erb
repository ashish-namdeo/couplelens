<div class="container py-4" style="max-width: 700px;">
  <div class="page-header">
    <h1>👨‍⚕️ Become a <span class="gradient-text">Therapist</span></h1>
    <p>Join our marketplace of licensed relationship professionals</p>
  </div>

  <%= form_with(model: @application, url: therapist_applications_path, class: 'animate-fade-in') do |f| %>
    <div class="glass-card-static p-4">
      <div class="row g-3">
        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :full_name, class: 'form-label' %>
            <%= f.text_field :full_name, class: 'form-control', placeholder: 'Dr. Jane Smith' %>
          </div>
        </div>
        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :email, class: 'form-label' %>
            <%= f.email_field :email, class: 'form-control', placeholder: 'jane@example.com' %>
          </div>
        </div>
        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :specialization, class: 'form-label' %>
            <%= f.select :specialization, TherapistProfile::SPECIALIZATIONS, { prompt: 'Select specialization' }, class: 'form-select' %>
          </div>
        </div>
        <div class="col-md-3">
          <div class="mb-3">
            <%= f.label :years_experience, 'Experience (years)', class: 'form-label' %>
            <%= f.number_field :years_experience, class: 'form-control', min: 0 %>
          </div>
        </div>
        <div class="col-md-3">
          <div class="mb-3">
            <%= f.label :hourly_rate, 'Rate ($/hr)', class: 'form-label' %>
            <%= f.number_field :hourly_rate, class: 'form-control', step: 5, min: 0 %>
          </div>
        </div>
        <div class="col-12">
          <div class="mb-3">
            <%= f.label :bio, 'Professional Bio', class: 'form-label' %>
            <%= f.text_area :bio, class: 'form-control', rows: 4, placeholder: 'Tell us about your experience and approach...' %>
          </div>
        </div>
        <div class="col-12">
          <div class="mb-3">
            <%= f.label :certifications, class: 'form-label' %>
            <%= f.text_area :certifications, class: 'form-control', rows: 3, placeholder: 'List your relevant certifications and licenses...' %>
          </div>
        </div>
      </div>

      <div class="d-flex gap-3 mt-3">
        <%= f.submit 'Submit Application', class: 'btn btn-gradient btn-lg' %>
        <%= link_to 'Cancel', root_path, class: 'btn btn-outline-glass btn-lg' %>
      </div>
    </div>
  <% end %>
</div>
