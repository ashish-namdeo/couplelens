<div class="container py-4">
  <div class="page-header">
    <h1>💰 Financial <span class="gradient-text">Harmony</span></h1>
    <p>Track shared expenses and manage your couple budget</p>
  </div>

  <!-- Summary Cards -->
  <div class="row g-4 mb-4">
    <div class="col-md-4">
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(108, 99, 255, 0.15);">💰</div>
        <div class="stat-value gradient-text">$<%= number_with_delimiter(@this_month_total.round(0)) %></div>
        <div class="stat-label">This Month Total</div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(255, 107, 157, 0.15);">🤝</div>
        <div class="stat-value" style="color: #FF6B9D;">$<%= number_with_delimiter(@shared_total.round(0)) %></div>
        <div class="stat-label">Shared Expenses</div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(46, 204, 113, 0.15);">📊</div>
        <div class="stat-value" style="color: #2ECC71;"><%= @expenses.count %></div>
        <div class="stat-label">Transactions</div>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <!-- Add Expense -->
    <div class="col-lg-4">
      <div class="glass-card-static p-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-plus-circle me-2" style="color: #6C63FF;"></i>Add Expense</h5>

        <%= form_with(model: @expense, url: expenses_path) do |f| %>
          <div class="mb-3">
            <%= f.label :category, class: 'form-label' %>
            <%= f.select :category, Expense::CATEGORIES, { prompt: 'Select category' }, class: 'form-select' %>
          </div>
          <div class="mb-3">
            <%= f.label :amount, class: 'form-label' %>
            <div class="input-group">
              <span class="input-group-text" style="background: rgba(26, 26, 46, 0.8); border-color: rgba(108, 99, 255, 0.15); color: #A0A0B8;">$</span>
              <%= f.number_field :amount, class: 'form-control', step: 0.01, placeholder: '0.00' %>
            </div>
          </div>
          <div class="mb-3">
            <%= f.label :description, class: 'form-label' %>
            <%= f.text_field :description, class: 'form-control', placeholder: 'What was this for?' %>
          </div>
          <div class="mb-3">
            <%= f.label :expense_date, class: 'form-label' %>
            <%= f.date_field :expense_date, class: 'form-control', value: Date.current %>
          </div>
          <div class="mb-3 form-check">
            <%= f.check_box :shared, class: 'form-check-input' %>
            <%= f.label :shared, 'Shared expense', class: 'form-check-label' %>
          </div>
          <%= f.submit 'Add Expense', class: 'btn btn-gradient w-100' %>
        <% end %>
      </div>

      <!-- Category Breakdown -->
      <% if @categories_data.any? %>
        <div class="glass-card-static p-4 mt-4">
          <h5 class="fw-bold mb-3">📊 By Category</h5>
          <% @categories_data.each do |category, amount| %>
            <div class="d-flex justify-content-between align-items-center mb-2">
              <span class="small"><%= category %></span>
              <span class="fw-bold small gradient-text">$<%= amount.round(0) %></span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Expense List -->
    <div class="col-lg-8">
      <div class="glass-card-static p-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-receipt me-2" style="color: #FF6B9D;"></i>Recent Expenses</h5>
        <% if @expenses.any? %>
          <div class="table-responsive">
            <table class="table table-dark-custom">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Description</th>
                  <th>Category</th>
                  <th>Amount</th>
                  <th>Type</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% @expenses.each do |expense| %>
                  <tr class="animate-fade-in">
                    <td><%= expense.expense_date.strftime('%b %d') %></td>
                    <td><%= expense.description %></td>
                    <td><span class="badge-glass"><%= expense.category %></span></td>
                    <td class="fw-bold">$<%= expense.amount.round(2) %></td>
                    <td>
                      <% if expense.shared? %>
                        <span class="badge bg-info">Shared</span>
                      <% else %>
                        <span class="badge bg-secondary">Personal</span>
                      <% end %>
                    </td>
                    <td>
                      <%= link_to expense, method: :delete, data: { confirm: 'Remove this expense?' }, class: 'btn btn-sm text-danger' do %>
                        <i class="bi bi-trash"></i>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="empty-state py-3">
            <div class="empty-icon">💰</div>
            <h3>No expenses yet</h3>
            <p>Start tracking your couple expenses to gain financial clarity.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
