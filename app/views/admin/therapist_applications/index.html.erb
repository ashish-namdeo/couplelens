<div class="container py-4">
  <div class="page-header">
    <h1>📋 Therapist <span class="gradient-text">Applications</span></h1>
    <p>Review and manage therapist applications</p>
  </div>

  <div class="glass-card-static p-4">
    <% if @applications.any? %>
      <div class="table-responsive">
        <table class="table table-dark-custom">
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Specialization</th>
              <th>Experience</th>
              <th>Rate</th>
              <th>Status</th>
              <th>Submitted</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% @applications.each do |app| %>
              <tr>
                <td class="fw-bold"><%= app.full_name %></td>
                <td><%= app.email %></td>
                <td><span class="badge-glass"><%= app.specialization %></span></td>
                <td><%= app.years_experience %> yrs</td>
                <td>$<%= app.hourly_rate&.round(0) %>/hr</td>
                <td>
                  <% case app.status %>
                  <% when 'submitted' %>
                    <span class="badge bg-warning text-dark">Submitted</span>
                  <% when 'under_review' %>
                    <span class="badge bg-info">Reviewing</span>
                  <% when 'approved' %>
                    <span class="badge bg-success">Approved</span>
                  <% when 'rejected' %>
                    <span class="badge bg-danger">Rejected</span>
                  <% end %>
                </td>
                <td><%= app.created_at.strftime('%b %d, %Y') %></td>
                <td>
                  <%= link_to 'Review', admin_therapist_application_path(app), class: 'btn btn-sm btn-outline-glass' %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-4" style="color: #888;">
        <p class="fs-1">📭</p>
        <p>No therapist applications yet.</p>
      </div>
    <% end %>
  </div>
</div>
