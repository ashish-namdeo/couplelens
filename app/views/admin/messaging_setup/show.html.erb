<style>
  .messaging-setup-card .card-body h3,
  .messaging-setup-card .card-body h5,
  .messaging-setup-card .card-body p,
  .messaging-setup-card .card-body li,
  .messaging-setup-card .card-body td,
  .messaging-setup-card .card-body th,
  .messaging-setup-card .card-body strong {
    color: #E0E0E0 !important;
  }
  .messaging-setup-card .card-body .text-muted {
    color: #AAAAAA !important;
  }
  .messaging-setup-card .card-body code {
    color: #E91E90;
    background: rgba(255,255,255,0.08);
    padding: 2px 6px;
    border-radius: 4px;
  }
</style>

<div class="container py-4">
  <div class="page-header">
    <h1>📱 Messaging Platform <span class="gradient-text">Setup</span></h1>
    <p>Connect CoupleLens to WhatsApp, Telegram, and other messaging platforms</p>
  </div>

  <!-- Status Overview -->
  <div class="row g-4 mb-4">
    <div class="col-md-6">
      <div class="stat-card text-center">
        <div class="stat-value" style="color: <%= @telegram_configured ? '#2ECC71' : '#E74C3C' %>;">
          <%= @telegram_configured ? '✅' : '❌' %>
        </div>
        <div class="stat-label">Telegram Bot</div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="stat-card text-center">
        <div class="stat-value" style="color: <%= @whatsapp_configured ? '#2ECC71' : '#E74C3C' %>;">
          <%= @whatsapp_configured ? '✅' : '❌' %>
        </div>
        <div class="stat-label">WhatsApp Business</div>
      </div>
    </div>
  </div>

  <!-- Telegram Setup -->
  <div class="card mb-4 messaging-setup-card" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px;">
    <div class="card-body p-4">
      <h3>🤖 Telegram Bot Setup</h3>
      <p class="text-muted">The easiest way to test — no cloud deployment needed!</p>

      <h5 class="mt-4">Step 1: Create a Bot</h5>
      <ol>
        <li>Open Telegram and search for <strong>@BotFather</strong></li>
        <li>Send <code>/newbot</code> and follow the prompts</li>
        <li>Choose a name (e.g., "CoupleLens Bot") and username (e.g., "couplelens_bot")</li>
        <li>Copy the bot token you receive</li>
      </ol>

      <h5 class="mt-4">Step 2: Configure</h5>
      <p>Add your bot token to the <code>.env</code> file:</p>
      <pre style="background: rgba(0,0,0,0.3); padding: 12px; border-radius: 8px; color: #2ECC71;">TELEGRAM_BOT_TOKEN=your_bot_token_here</pre>

      <h5 class="mt-4">Step 3: Expose Your Local Server</h5>
      <p>Use ngrok to make your local server accessible:</p>
      <pre style="background: rgba(0,0,0,0.3); padding: 12px; border-radius: 8px; color: #2ECC71;">ngrok http 3000</pre>
      <p>Copy the HTTPS URL (e.g., <code>https://abc123.ngrok.io</code>)</p>

      <h5 class="mt-4">Step 4: Set Webhook</h5>
      <p>Run this Rake task to register your webhook with Telegram:</p>
      <pre style="background: rgba(0,0,0,0.3); padding: 12px; border-radius: 8px; color: #2ECC71;">rails messaging:telegram:set_webhook URL=https://abc123.ngrok.io</pre>
      <p>Or manually:</p>
      <pre style="background: rgba(0,0,0,0.3); padding: 12px; border-radius: 8px; color: #2ECC71;">curl "https://api.telegram.org/bot&lt;TOKEN&gt;/setWebhook?url=https://abc123.ngrok.io/api/v1/webhooks/telegram/&lt;TOKEN&gt;"</pre>

      <h5 class="mt-4">Step 5: Test!</h5>
      <p>Open Telegram, find your bot, and send <code>/start</code> 🎉</p>

      <% if @telegram_configured %>
        <div class="alert mt-3" style="background: rgba(46,204,113,0.15); border: 1px solid rgba(46,204,113,0.3); border-radius: 8px; color: #2ECC71;">
          ✅ Telegram bot token is configured!
        </div>

        <div class="mt-3 d-flex gap-2">
          <%= button_to "🔗 Set Telegram Webhook (use current ngrok URL)", admin_set_telegram_webhook_path, method: :post, class: "btn btn-success", data: { confirm: "This will register the Telegram webhook with your current WEBHOOK_BASE_URL. Continue?" } %>
          <%= link_to "ℹ️ Check Webhook Info", admin_telegram_webhook_info_path, class: "btn btn-outline-light" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- WhatsApp Setup -->
  <div class="card mb-4 messaging-setup-card" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px;">
    <div class="card-body p-4">
      <h3>💬 WhatsApp Business Setup</h3>
      <p class="text-muted">Connect via Meta's WhatsApp Cloud API (free test mode available)</p>

      <h5 class="mt-4">Step 1: Meta Developer Account</h5>
      <ol>
        <li>Go to <strong>developers.facebook.com</strong> and create an account</li>
        <li>Create a new App → select "Business" type</li>
        <li>Add the "WhatsApp" product</li>
      </ol>

      <h5 class="mt-4">Step 2: Get Credentials</h5>
      <p>From the WhatsApp section of your Meta app dashboard, copy:</p>
      <ul>
        <li><strong>Temporary access token</strong> (for testing)</li>
        <li><strong>Phone number ID</strong></li>
      </ul>

      <h5 class="mt-4">Step 3: Configure</h5>
      <p>Add these to your <code>.env</code> file:</p>
      <pre style="background: rgba(0,0,0,0.3); padding: 12px; border-radius: 8px; color: #2ECC71;">WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=couplelens_webhook_verify_2026</pre>

      <h5 class="mt-4">Step 4: Set Webhook</h5>
      <p>In the Meta app dashboard, configure the webhook:</p>
      <ul>
        <li><strong>Callback URL:</strong> <code>https://your-ngrok-url/api/v1/webhooks/whatsapp</code></li>
        <li><strong>Verify token:</strong> <code>couplelens_webhook_verify_2026</code> (or your custom token)</li>
        <li><strong>Subscribe to:</strong> <code>messages</code></li>
      </ul>

      <h5 class="mt-4">Step 5: Test!</h5>
      <p>Use the test phone number from Meta's dashboard to send a message 🎉</p>

      <% if @whatsapp_configured %>
        <div class="alert mt-3" style="background: rgba(46,204,113,0.15); border: 1px solid rgba(46,204,113,0.3); border-radius: 8px; color: #2ECC71;">
          ✅ WhatsApp access token is configured!
        </div>
      <% end %>
    </div>
  </div>

  <!-- Bot Commands Reference -->
  <div class="card mb-4 messaging-setup-card" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px;">
    <div class="card-body p-4">
      <h3>🎮 Bot Commands</h3>
      <p>Available commands users can send via messaging platforms:</p>

      <table class="table" style="color: inherit;">
        <thead>
          <tr>
            <th>Command</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr><td><code>/start</code></td><td>Welcome message and command list</td></tr>
          <tr><td><code>/help</code></td><td>Show available commands</td></tr>
          <tr><td><code>/rewrite &lt;message&gt;</code></td><td>Rewrite a heated message to be calmer</td></tr>
          <tr><td><code>/persona &lt;type&gt;</code></td><td>Change AI persona (clinical_psychologist, empathetic_listener, etc.)</td></tr>
          <tr><td><code>/reset</code></td><td>Start a fresh conversation</td></tr>
          <tr><td><em>Any text</em></td><td>Chat with the AI relationship assistant</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Webhook URLs -->
  <div class="card mb-4 messaging-setup-card" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px;">
    <div class="card-body p-4">
      <h3>🔗 Webhook URLs</h3>
      <p>Use these endpoints with your ngrok or production URL:</p>

      <table class="table" style="color: inherit;">
        <thead>
          <tr>
            <th>Platform</th>
            <th>Endpoint</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Telegram</td>
            <td><code>POST /api/v1/webhooks/telegram/:token</code></td>
          </tr>
          <tr>
            <td>WhatsApp (verify)</td>
            <td><code>GET /api/v1/webhooks/whatsapp</code></td>
          </tr>
          <tr>
            <td>WhatsApp (receive)</td>
            <td><code>POST /api/v1/webhooks/whatsapp</code></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="text-center">
    <%= link_to '← Back to Admin Dashboard', admin_dashboard_path, class: 'btn btn-outline-light' %>
  </div>
</div>
