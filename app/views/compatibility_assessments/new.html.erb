<div class="container py-4" style="max-width: 600px;">
  <div class="page-header">
    <h1>💕 New <span class="gradient-text">Assessment</span></h1>
    <p>Start your compatibility evaluation</p>
  </div>

  <%= form_with(model: @assessment, class: 'animate-fade-in') do |f| %>
    <div class="glass-card-static p-4">
      <div class="mb-4">
        <%= f.label :partner_name, "Your Partner's Name", class: 'form-label' %>
        <%= f.text_field :partner_name, class: 'form-control', placeholder: "Enter your partner's name" %>
      </div>

      <div class="glass-card p-3 mb-4" style="background: rgba(108, 99, 255, 0.05);">
        <h6 class="fw-bold mb-2"><i class="bi bi-info-circle me-1"></i> What We'll Assess</h6>
        <ul class="list-unstyled small text-muted mb-0">
          <li class="mb-1">💰 Financial mindset & money management compatibility</li>
          <li class="mb-1">🏡 Lifestyle choices & daily routine alignment</li>
          <li class="mb-1">👶 Parenting philosophy & family values</li>
          <li>📊 Overall compatibility score with detailed report</li>
        </ul>
      </div>

      <div class="d-flex gap-3">
        <%= f.submit 'Generate Assessment', class: 'btn btn-gradient btn-lg' %>
        <%= link_to 'Cancel', compatibility_assessments_path, class: 'btn btn-outline-glass btn-lg' %>
      </div>
    </div>
  <% end %>
</div>
