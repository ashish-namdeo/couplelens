<div class="container py-4">
  <div class="page-header">
    <h1>Welcome back, <span class="gradient-text"><%= current_user.first_name %></span> 👋</h1>
    <p>Here's your relationship overview</p>
  </div>

  <!-- Stats Row -->
  <div class="row g-4 mb-4">
    <div class="col-md-3 col-6">
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(108, 99, 255, 0.15);">💬</div>
        <div class="stat-value gradient-text"><%= @total_conversations %></div>
        <div class="stat-label">Conversations</div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(46, 204, 113, 0.15);">📊</div>
        <div class="stat-value" style="color: #2ECC71;"><%= @avg_health_score %>%</div>
        <div class="stat-label">Health Score</div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(255, 107, 157, 0.15);">👨‍⚕️</div>
        <div class="stat-value" style="color: #FF6B9D;"><%= @total_sessions %></div>
        <div class="stat-label">Therapy Sessions</div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="stat-card">
        <div class="stat-icon" style="background: rgba(243, 156, 18, 0.15);">💝</div>
        <div class="stat-value" style="color: #F39C12;"><%= @memories_count %></div>
        <div class="stat-label">Memories</div>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <!-- Quick Actions -->
    <div class="col-lg-8">
      <div class="glass-card-static p-4 mb-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-lightning-fill text-warning me-2"></i>Quick Actions</h5>
        <div class="row g-3">
          <div class="col-md-4">
            <%= link_to new_conversation_path, class: 'glass-card p-3 text-center text-decoration-none d-block' do %>
              <div style="font-size: 2rem;">🤖</div>
              <div class="fw-bold small mt-2">New AI Chat</div>
            <% end %>
          </div>
          <div class="col-md-4">
            <%= link_to new_conflict_session_path, class: 'glass-card p-3 text-center text-decoration-none d-block' do %>
              <div style="font-size: 2rem;">⚖️</div>
              <div class="fw-bold small mt-2">Start Mediation</div>
            <% end %>
          </div>
          <div class="col-md-4">
            <%= link_to rewrite_path, class: 'glass-card p-3 text-center text-decoration-none d-block' do %>
              <div style="font-size: 2rem;">✏️</div>
              <div class="fw-bold small mt-2">Rewrite Message</div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Recent Conversations -->
      <div class="glass-card-static p-4 mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h5 class="fw-bold mb-0"><i class="bi bi-chat-dots-fill me-2" style="color: #6C63FF;"></i>Recent Conversations</h5>
          <%= link_to 'View All', conversations_path, class: 'btn btn-sm btn-outline-glass' %>
        </div>
        <% if @recent_conversations.any? %>
          <% @recent_conversations.each do |conv| %>
            <%= link_to conv, class: 'glass-card p-3 mb-2 d-block text-decoration-none' do %>
              <div class="d-flex align-items-center justify-content-between">
                <div>
                  <span class="me-2"><%= conv.persona_icon %></span>
                  <span class="fw-bold"><%= conv.title %></span>
                  <span class="badge-glass ms-2"><%= conv.persona_display_name %></span>
                </div>
                <small class="text-muted"><%= time_ago_in_words(conv.updated_at) %> ago</small>
              </div>
            <% end %>
          <% end %>
        <% else %>
          <div class="empty-state py-3">
            <p class="text-muted">No conversations yet. Start your first AI chat!</p>
          </div>
        <% end %>
      </div>

      <!-- Telegram Conversations -->
      <% if @telegram_conversations.any? %>
        <div class="glass-card-static p-4 mb-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0"><span class="me-2">✈️</span>Telegram Conversations</h5>
            <span class="badge" style="background: rgba(0, 136, 204, 0.2); color: #0088cc;"><%= @telegram_conversations.size %> chats</span>
          </div>
          <% @telegram_conversations.each do |conv| %>
            <%= link_to conv, class: 'glass-card p-3 mb-2 d-block text-decoration-none' do %>
              <div class="d-flex align-items-center justify-content-between">
                <div>
                  <span class="me-2"><%= conv.persona_icon %></span>
                  <span class="fw-bold"><%= conv.title %></span>
                  <span class="badge-glass ms-2"><%= conv.persona_display_name %></span>
                  <span class="badge ms-1" style="background: rgba(0, 136, 204, 0.15); color: #0088cc; font-size: 0.7rem;">Telegram</span>
                </div>
                <div class="text-end">
                  <small class="text-muted d-block"><%= conv.messages.count %> msgs</small>
                  <small class="text-muted"><%= time_ago_in_words(conv.updated_at) %> ago</small>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <!-- WhatsApp Conversations -->
      <% if @whatsapp_conversations.any? %>
        <div class="glass-card-static p-4 mb-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0"><span class="me-2">📱</span>WhatsApp Conversations</h5>
            <span class="badge" style="background: rgba(37, 211, 102, 0.2); color: #25D366;"><%= @whatsapp_conversations.size %> chats</span>
          </div>
          <% @whatsapp_conversations.each do |conv| %>
            <%= link_to conv, class: 'glass-card p-3 mb-2 d-block text-decoration-none' do %>
              <div class="d-flex align-items-center justify-content-between">
                <div>
                  <span class="me-2"><%= conv.persona_icon %></span>
                  <span class="fw-bold"><%= conv.title %></span>
                  <span class="badge-glass ms-2"><%= conv.persona_display_name %></span>
                  <span class="badge ms-1" style="background: rgba(37, 211, 102, 0.15); color: #25D366; font-size: 0.7rem;">WhatsApp</span>
                </div>
                <div class="text-end">
                  <small class="text-muted d-block"><%= conv.messages.count %> msgs</small>
                  <small class="text-muted"><%= time_ago_in_words(conv.updated_at) %> ago</small>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
      <!-- Link Bot Account -->
      <div class="glass-card-static p-4 mb-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-phone-fill me-2" style="color: #6C63FF;"></i>Link Bot Account</h5>
        <% if @bot_linked %>
          <div class="d-flex align-items-center mb-2">
            <span class="badge bg-success me-2">Connected</span>
            <% if current_user.whatsapp_id.present? %>
              <span class="badge-glass me-1">📱 WhatsApp</span>
            <% end %>
            <% if current_user.telegram_id.present? %>
              <span class="badge-glass">✈️ Telegram</span>
            <% end %>
          </div>
          <p class="text-muted small mb-3">Your bot account is linked. You can use CoupleLens via messaging apps.</p>

          <!-- Link another platform -->
          <% unless current_user.whatsapp_id.present? %>
            <div class="mb-2">
              <div class="input-group input-group-sm">
                <input type="text" id="wa-phone" class="form-control" placeholder="WhatsApp number (e.g. 919876543210)" style="background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1); color: #fff;">
                <button class="btn btn-sm" style="background: rgba(37, 211, 102, 0.2); color: #25D366;" onclick="sendLinkInvitation('whatsapp')">📱 Send Link</button>
              </div>
            </div>
          <% end %>
          <% unless current_user.telegram_id.present? %>
            <div class="mb-2">
              <button class="btn btn-sm w-100" style="background: rgba(0, 136, 204, 0.2); color: #0088cc;" onclick="linkViaTelegram()">✈️ Link Telegram Account</button>
            </div>
          <% end %>

          <div id="link-invitation-result" class="mb-2" style="display: none;"></div>

          <hr style="border-color: rgba(255,255,255,0.1);">
          <button class="btn btn-sm btn-outline-glass w-100" id="generate-link-code-btn" onclick="generateLinkCode()">
            🔗 Or Use Link Code
          </button>
          <div id="link-code-display" class="mt-2" style="display: none;">
            <div class="glass-card p-3 text-center">
              <div class="text-muted small">Your link code:</div>
              <div class="fw-bold gradient-text" style="font-size: 1.5rem; letter-spacing: 2px;" id="link-code-value"></div>
              <div class="text-muted" style="font-size: 0.75rem;">Expires in 30 minutes</div>
              <div class="text-muted small mt-1">Send <code>/link CODE</code> on WhatsApp or Telegram</div>
            </div>
          </div>
        <% else %>
          <p class="text-muted small mb-3">Connect your WhatsApp or Telegram to use CoupleLens as a chatbot.</p>

          <!-- WhatsApp Link - Instant Code Method -->
          <div class="mb-3">
            <label class="text-muted small mb-1 d-block">📱 WhatsApp</label>
            <div class="input-group input-group-sm mb-2">
              <input type="text" id="wa-phone-number" class="form-control" placeholder="Enter your phone (e.g. 919876543210)" style="background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1); color: #fff;">
              <button class="btn btn-sm" style="background: rgba(37, 211, 102, 0.2); color: #25D366;" onclick="generateWhatsAppLink()">📱 Get Link Code</button>
            </div>
            <div id="wa-link-display" class="glass-card p-3" style="display: none;">
              <div class="text-center mb-2">
                <div class="text-muted small">Your link code:</div>
                <div class="fw-bold gradient-text" style="font-size: 1.3rem; letter-spacing: 2px;" id="wa-code-value"></div>
                <div class="text-muted" style="font-size: 0.7rem;">Expires in 30 minutes</div>
              </div>
              <div class="alert alert-success py-2 px-3 small mb-2" style="background: rgba(25, 135, 84, 0.1); border-color: rgba(25, 135, 84, 0.3);">
                <strong>📲 Easy Way:</strong><br>
                Click the button below - WhatsApp will open automatically with everything ready!
              </div>
              <button class="btn btn-sm w-100 mb-2" style="background: rgba(37, 211, 102, 0.4); color: #25D366; font-weight: bold;" onclick="openWhatsAppChat()">
                💬 Open WhatsApp & Send
              </button>
              <div class="text-muted text-center" style="font-size: 0.65rem;">
                Or manually message the bot with: <code>/link <span id="wa-code-copy"></span></code>
              </div>
            </div>
          </div>

          <div class="mb-3">
            <label class="text-muted small mb-1 d-block">✈️ Telegram</label>
            <button class="btn btn-sm w-100" style="background: rgba(0, 136, 204, 0.2); color: #0088cc;" onclick="linkViaTelegram()">✈️ Link via Telegram</button>
            <div class="text-muted" style="font-size: 0.65rem; margin-top: 0.25rem;">Opens Telegram and links automatically</div>
          </div>
          </div>
        <% end %>
      </div>

      <!-- Upcoming Bookings -->
      <div class="glass-card-static p-4 mb-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-calendar-check-fill me-2" style="color: #FF6B9D;"></i>Upcoming Sessions</h5>
        <% if @upcoming_bookings.any? %>
          <% @upcoming_bookings.each do |booking| %>
            <div class="glass-card p-3 mb-2">
              <div class="fw-bold small"><%= booking.therapist_profile.user.full_name %></div>
              <div class="text-muted" style="font-size: 0.8rem;">
                <i class="bi bi-clock me-1"></i><%= booking.scheduled_at.strftime('%B %d, %I:%M %p') %>
              </div>
              <span class="badge-glass mt-1 d-inline-block"><%= booking.session_type %></span>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted small">No upcoming sessions. <%= link_to 'Browse therapists', therapists_path, class: 'text-decoration-none' %></p>
        <% end %>
      </div>

      <!-- Active Programs -->
      <div class="glass-card-static p-4 mb-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-book-fill me-2" style="color: #2ECC71;"></i>Active Programs</h5>
        <% if @active_programs.any? %>
          <% @active_programs.each do |up| %>
            <div class="glass-card p-3 mb-2">
              <div class="fw-bold small"><%= up.program.title %></div>
              <div class="progress mt-2" style="height: 6px;">
                <div class="progress-bar" style="width: <%= up.program.progress_for(current_user) %>%"></div>
              </div>
              <div class="text-muted mt-1" style="font-size: 0.75rem;"><%= up.program.progress_for(current_user) %>% complete</div>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted small">No active programs. <%= link_to 'Browse programs', programs_path, class: 'text-decoration-none' %></p>
        <% end %>
      </div>

      <!-- Recent Memories -->
      <div class="glass-card-static p-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-heart-fill me-2" style="color: #F39C12;"></i>Recent Memories</h5>
        <% if @recent_memories.any? %>
          <% @recent_memories.each do |memory| %>
            <div class="d-flex align-items-start mb-3">
              <span class="me-2" style="font-size: 1.2rem;"><%= memory.memory_icon %></span>
              <div>
                <div class="fw-bold small"><%= memory.title %></div>
                <div class="text-muted" style="font-size: 0.75rem;"><%= memory.memory_date.strftime('%B %d, %Y') %></div>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted small">No memories yet. <%= link_to 'Add your first', new_memory_path, class: 'text-decoration-none' %></p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  function sendLinkInvitation(platform) {
    var params = {};
    var btn;

    if (platform === 'whatsapp') {
      var phone = document.getElementById('wa-phone').value.trim();
      if (!phone) { alert('Please enter a WhatsApp phone number'); return; }
      params = { platform: 'whatsapp', phone_number: phone };
      btn = document.getElementById('wa-phone').nextElementSibling || event.target;
    } else {
      var chatId = document.getElementById('tg-chat-id').value.trim();
      if (!chatId) { alert('Please enter a Telegram Chat ID'); return; }
      params = { platform: 'telegram', telegram_chat_id: chatId };
      btn = document.getElementById('tg-chat-id').nextElementSibling || event.target;
    }

    var originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Sending...';

    fetch('<%= send_link_invitation_path %>', {
      method: 'POST',
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify(params)
    })
    .then(function(response) { return response.json(); })
    .then(function(data) {
      var resultDiv = document.getElementById('link-invitation-result');
      if (resultDiv) {
        resultDiv.style.display = 'block';
        if (data.success) {
          resultDiv.innerHTML = '<div class="alert alert-success py-2 px-3 small mb-0" style="background: rgba(25, 135, 84, 0.1); border-color: rgba(25, 135, 84, 0.3); color: #75b798;">✅ ' + data.message + '</div>';
        } else {
          resultDiv.innerHTML = '<div class="alert alert-warning py-2 px-3 small mb-0" style="background: rgba(255, 193, 7, 0.1); border-color: rgba(255, 193, 7, 0.3); color: #ffc107;">' + 
            '<strong>💡 Try Link Code Instead:</strong><br>' + 
            '<span class="text-muted" style="font-size: 0.85rem;">' + data.message + '</span><br>' +
            '<button class="btn btn-sm mt-2" style="background: rgba(255, 255, 255, 0.15); color: #fff;" onclick="generateLinkCode(); document.getElementById(\'link-invitation-result\').style.display=\'none\';">Generate Link Code</button>' +
            '</div>';
        }
      } else {
        alert(data.success ? '✅ ' + data.message : '💡 ' + data.message);
      }
      btn.textContent = originalText;
      btn.disabled = false;
    })
    .catch(function() {
      btn.textContent = '❌ Error';
      setTimeout(function() { btn.textContent = originalText; btn.disabled = false; }, 2000);
    });
  }

  function linkViaTelegram() {
    var btn = event.target;
    var originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Generating link...';

    fetch('<%= generate_telegram_link_path %>', {
      method: 'POST',
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
        'Accept': 'application/json'
      }
    })
    .then(function(response) { return response.json(); })
    .then(function(data) {
      if (data.success) {
        window.open(data.link, '_blank');
        var resultDiv = document.getElementById('link-invitation-result');
        if (resultDiv) {
          resultDiv.style.display = 'block';
          resultDiv.innerHTML = '<div class="alert alert-info py-1 px-2 small mb-0">✈️ Telegram opened! Tap <strong>Start</strong> to link your account, then refresh this page.</div>';
        }
      } else {
        alert('Failed to generate link. Please try again.');
      }
      btn.textContent = originalText;
      btn.disabled = false;
    })
    .catch(function() {
      btn.textContent = '❌ Error';
      setTimeout(function() { btn.textContent = originalText; btn.disabled = false; }, 2000);
    });
  }

  function generateLinkCode() {
    var btn = document.getElementById('generate-link-code-btn');
    btn.disabled = true;
    btn.textContent = 'Generating...';

    fetch('<%= generate_bot_link_code_path %>', {
      method: 'POST',
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
        'Accept': 'application/json'
      }
    })
    .then(function(response) { return response.json(); })
    .then(function(data) {
      document.getElementById('link-code-value').textContent = data.code;
      var copyEl = document.getElementById('link-code-copy');
      if (copyEl) copyEl.textContent = data.code;
      document.getElementById('link-code-display').style.display = 'block';
      btn.textContent = '🔄 Regenerate Code';
      btn.disabled = false;
    })
    .catch(function() {
      btn.textContent = '❌ Error. Try again.';
      btn.disabled = false;
    });
  }

  // New WhatsApp-specific link code generation
  var currentWhatsAppCode = null;
  var currentWhatsAppPhone = null;

  function generateWhatsAppLink() {
    var phoneInput = document.getElementById('wa-phone-number');
    var phone = phoneInput.value.trim();
    
    if (!phone) {
      alert('Please enter a phone number');
      return;
    }

    var btn = event.target;
    var originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Generating...';

    fetch('<%= generate_bot_link_code_path %>', {
      method: 'POST',
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
        'Accept': 'application/json'
      }
    })
    .then(function(response) { return response.json(); })
    .then(function(data) {
      currentWhatsAppCode = data.code;
      currentWhatsAppPhone = phone;
      
      document.getElementById('wa-code-value').textContent = data.code;
      var copyEl = document.getElementById('wa-code-copy');
      if (copyEl) copyEl.textContent = data.code;
      document.getElementById('wa-link-display').style.display = 'block';
      
      btn.textContent = originalText;
      btn.disabled = false;
    })
    .catch(function() {
      btn.textContent = '❌ Error';
      setTimeout(function() { btn.textContent = originalText; btn.disabled = false; }, 2000);
    });
  }

  function openWhatsAppChat() {
    <% bot_phone = ENV['WHATSAPP_DISPLAY_PHONE'] %>
    <% if bot_phone.present? && bot_phone != '+1234567890' %>
      var botNumber = '<%= bot_phone.gsub(/[^\d]/, '') %>';
    <% else %>
      var botNumber = ''; 
    <% end %>
    
    if (!botNumber) {
      alert('⚠️ WhatsApp bot number not configured yet.\n\nPlease:\n1. Find your bot number in Meta Developer Dashboard\n2. Add it to .env as WHATSAPP_DISPLAY_PHONE=+15551595614\n3. Restart the server\n\nFor now, manually message the bot with: /link ' + currentWhatsAppCode);
      return;
    }

    var message = encodeURIComponent('/link ' + currentWhatsAppCode);
    var whatsappUrl = 'https://wa.me/' + botNumber + '?text=' + message;
    window.open(whatsappUrl, '_blank');
  }
</script>
