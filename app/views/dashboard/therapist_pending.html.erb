<div class="container py-5" style="max-width: 700px;">
  <div class="text-center animate-fade-in">
    <div class="mb-4" style="font-size: 5rem;">⏳</div>
    <h1 class="fw-bold mb-3">Application <span class="gradient-text">Under Review</span></h1>
    <p style="color: #aaa; font-size: 1.1rem;">
      Thank you for signing up, <strong><%= current_user.full_name %></strong>! Your therapist application has been submitted and is being reviewed by our admin team.
    </p>
  </div>

  <div class="glass-card-static p-4 mt-4">
    <h5 class="fw-bold mb-3">📋 Application Summary</h5>
    <div class="row g-3">
      <div class="col-md-6">
        <span style="color: #888;">Full Name</span><br>
        <strong><%= @application.full_name %></strong>
      </div>
      <div class="col-md-6">
        <span style="color: #888;">Email</span><br>
        <strong><%= @application.email %></strong>
      </div>
      <div class="col-md-6">
        <span style="color: #888;">Specialization</span><br>
        <span class="badge-glass"><%= @application.specialization %></span>
      </div>
      <div class="col-md-6">
        <span style="color: #888;">Experience</span><br>
        <strong><%= @application.years_experience %> years</strong>
      </div>
      <div class="col-md-6">
        <span style="color: #888;">Hourly Rate</span><br>
        <strong style="color: #2ECC71;">$<%= @application.hourly_rate.to_i %>/hr</strong>
      </div>
      <div class="col-md-6">
        <span style="color: #888;">Status</span><br>
        <span class="badge bg-warning text-dark">Pending Review</span>
      </div>
      <div class="col-12">
        <span style="color: #888;">Submitted</span><br>
        <strong><%= @application.created_at.strftime('%B %d, %Y at %I:%M %p') %></strong>
      </div>
    </div>
  </div>

  <div class="glass-card-static p-4 mt-4">
    <h5 class="fw-bold mb-3">🔄 What happens next?</h5>
    <div class="d-flex align-items-start mb-3">
      <span class="badge bg-success me-3 mt-1">✓</span>
      <div>
        <strong>Application Submitted</strong><br>
        <small style="color: #888;">Your details have been received</small>
      </div>
    </div>
    <div class="d-flex align-items-start mb-3">
      <span class="badge bg-warning text-dark me-3 mt-1">2</span>
      <div>
        <strong>Admin Review</strong><br>
        <small style="color: #888;">Our team will verify your credentials and qualifications</small>
      </div>
    </div>
    <div class="d-flex align-items-start mb-3">
      <span class="badge bg-secondary me-3 mt-1">3</span>
      <div>
        <strong>Approval & Profile Setup</strong><br>
        <small style="color: #888;">Once approved, your therapist profile will be created and visible to clients</small>
      </div>
    </div>
    <div class="d-flex align-items-start">
      <span class="badge bg-secondary me-3 mt-1">4</span>
      <div>
        <strong>Start Accepting Clients</strong><br>
        <small style="color: #888;">Clients can browse your profile and book sessions with you</small>
      </div>
    </div>
  </div>
</div>
