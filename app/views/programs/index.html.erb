<div class="container py-4">
  <div class="page-header">
    <h1>📚 Guided Relationship <span class="gradient-text">Programs</span></h1>
    <p>Structured courses to strengthen your relationship</p>
  </div>

  <% if @programs.any? %>
    <div class="row g-4">
      <% @programs.each do |program| %>
        <div class="col-md-6 col-lg-4 animate-fade-in-up">
          <div class="glass-card p-4 h-100 d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <span class="badge-gradient"><%= program.category %></span>
              <span class="badge-glass"><%= program.difficulty %></span>
            </div>
            <h5 class="fw-bold mt-2"><%= program.title %></h5>
            <p class="text-muted small flex-grow-1"><%= program.description.truncate(120) %></p>

            <div class="d-flex justify-content-between align-items-center mb-3">
              <span class="text-muted small"><i class="bi bi-clock me-1"></i><%= program.duration_weeks %> weeks</span>
              <span class="text-muted small"><i class="bi bi-book me-1"></i><%= program.lessons.count %> lessons</span>
            </div>

            <% user_program = @my_programs.find { |up| up.program_id == program.id } %>
            <% if user_program %>
              <div class="mb-2">
                <div class="progress" style="height: 6px;">
                  <div class="progress-bar" style="width: <%= program.progress_for(current_user) %>%"></div>
                </div>
                <small class="text-muted"><%= program.progress_for(current_user) %>% complete</small>
              </div>
              <%= link_to 'Continue', program, class: 'btn btn-gradient btn-sm w-100' %>
            <% else %>
              <%= link_to 'View Program', program, class: 'btn btn-outline-glass btn-sm w-100' %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="glass-card-static p-5">
      <div class="empty-state">
        <div class="empty-icon">📚</div>
        <h3>Programs coming soon</h3>
        <p>We're creating amazing relationship growth programs. Check back soon!</p>
      </div>
    </div>
  <% end %>
</div>
