<div class="hero-section">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6 mb-5 mb-lg-0">
        <span class="badge-gradient mb-3 d-inline-block">✨ The Future of Relationships</span>
        <h1 class="display-4 fw-bold mb-4" style="line-height: 1.15;">
          Your Relationship<br>
          <span class="gradient-text">AI Companion</span>
        </h1>
        <p class="lead mb-4" style="color: #A0A0B8; font-size: 1.15rem; line-height: 1.7;">
          CoupleLens uses AI to help couples communicate better, resolve conflicts, and understand each other — anytime, anywhere.
        </p>
        <div class="d-flex gap-3 flex-wrap">
          <%= link_to new_user_registration_path, class: 'btn btn-gradient btn-lg px-4' do %>
            <span>Get Started Free <i class="bi bi-arrow-right ms-1"></i></span>
          <% end %>
          <a href="#features" class="btn btn-outline-glass btn-lg px-4">See What It Does</a>
        </div>
        <div class="d-flex gap-4 mt-4 pt-2">
          <div>
            <div class="fw-bold" style="font-size: 1.5rem;">4</div>
            <div class="small text-muted">AI Tools</div>
          </div>
          <div>
            <div class="fw-bold" style="font-size: 1.5rem;">24/7</div>
            <div class="small text-muted">Always Available</div>
          </div>
          <div>
            <div class="fw-bold" style="font-size: 1.5rem;">4.9★</div>
            <div class="small text-muted">User Rating</div>
          </div>
        </div>
      </div>
      <div class="col-lg-6 text-center">
        <div class="glass-card-static p-4" style="animation: pulse-glow 3s ease-in-out infinite;">
          <div class="row g-3">
            <div class="col-6">
              <div class="glass-card p-3 text-center">
                <div style="font-size: 2.5rem;">🤖</div>
                <div class="fw-bold small mt-2">AI Advisor</div>
              </div>
            </div>
            <div class="col-6">
              <div class="glass-card p-3 text-center">
                <div style="font-size: 2.5rem;">⚖️</div>
                <div class="fw-bold small mt-2">Resolve Your Conflict</div>
              </div>
            </div>
            <div class="col-6">
              <div class="glass-card p-3 text-center">
                <div style="font-size: 2.5rem;">✏️</div>
                <div class="fw-bold small mt-2">Improve Your Message</div>
              </div>
            </div>
            <div class="col-6">
              <div class="glass-card p-3 text-center">
                <div style="font-size: 2.5rem;">💕</div>
                <div class="fw-bold small mt-2">Compatibility</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Features Section -->
<section id="features" class="py-5">
  <div class="container">
    <div class="text-center mb-5">
      <span class="badge-glass mb-3 d-inline-block">AI Tools</span>
      <h2 class="fw-bold display-6">Everything You Need to Thrive Together</h2>
      <p class="text-muted" style="max-width: 560px; margin: 0 auto;">
        Four powerful AI tools designed specifically to help couples communicate, connect, and grow.
      </p>
    </div>

    <div class="row g-4 justify-content-center">
      <div class="col-md-6 col-lg-3">
        <div class="feature-card h-100">
          <div class="feature-icon">🤖</div>
          <h3>AI Relationship Advisor</h3>
          <p>Chat with an empathetic AI companion across multiple personas. Get guidance on recurring issues and communication strategies — anytime.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="feature-card h-100">
          <div class="feature-icon">⚖️</div>
          <h3>Resolve Your Conflict</h3>
          <p>Structured conflict resolution powered by AI. Submit both perspectives and receive a balanced, neutral analysis to move forward together.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="feature-card h-100">
          <div class="feature-icon">✏️</div>
          <h3>Improve Your Message</h3>
          <p>Paste a heated or unclear message, and the AI will rewrite it to be calmer, more respectful, and emotionally intelligent.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="feature-card h-100">
          <div class="feature-icon">💕</div>
          <h3>Compatibility Check</h3>
          <p>Assess your relationship compatibility across values, lifestyle, and communication styles. Receive a detailed, personalized report.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<% if false # Pricing section hidden — coming soon %>
<!-- Pricing Section -->
<section class="py-5">
  <div class="container">
    <div class="text-center mb-5">
      <span class="badge-glass mb-3 d-inline-block">Pricing Plans</span>
      <h2 class="fw-bold display-6">Invest in Your Relationship</h2>
    </div>
    <!-- pricing cards here -->
  </div>
</section>
<% end %>

<!-- CTA Section -->
<section class="py-5 mb-4">
  <div class="container">
    <div class="glass-card-static p-5 text-center" style="background: linear-gradient(135deg, rgba(108, 99, 255, 0.1), rgba(255, 107, 157, 0.05));">
      <h2 class="fw-bold display-6 mb-3">Ready to Strengthen Your Relationship?</h2>
      <p class="text-muted mb-4" style="max-width: 500px; margin: 0 auto;">Join couples already using CoupleLens to communicate better and understand each other more deeply.</p>
      <%= link_to new_user_registration_path, class: 'btn btn-gradient btn-lg px-5' do %>
        <span>Start for Free <i class="bi bi-heart-fill ms-1"></i></span>
      <% end %>
    </div>
  </div>
</section>
