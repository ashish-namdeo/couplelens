      <p class="text-muted mb-4" style="max-width: 500px; margin: 0 auto;">Join thousands of couples who are already building stronger, healthier relationships with CoupleLens.</p>
      <%= link_to new_user_registration_path, class: 'btn btn-gradient btn-lg px-5' do %>
        <span>Start Your Journey <i class="bi bi-heart-fill ms-1"></i></span>
      <% end %>
    </div>
  </div>
</section>
