            <div class="fw-bold" style="font-size: 1.5rem;">200+</div>
            <div class="small text-muted">Licensed Therapists</div>
          </div>
          <div>
            <div class="fw-bold" style="font-size: 1.5rem;">4.9★</div>
            <div class="small text-muted">User Rating</div>
          </div>
        </div>
      </div>
      <div class="col-lg-6 text-center">
        <div class="glass-card-static p-4" style="animation: pulse-glow 3s ease-in-out infinite;">
          <div class="row g-3">
            <div class="col-6">
              <div class="glass-card p-3 text-center">
                <div style="font-size: 2.5rem;">🤖</div>
                <div class="fw-bold small mt-2">AI Assistant</div>
              </div>
            </div>
            <div class="col-6">
              <div class="glass-card p-3 text-center">
                <div style="font-size: 2.5rem;">⚖️</div>
                <div class="fw-bold small mt-2">Conflict Mediator</div>
              </div>
            </div>
            <div class="col-6">
              <div class="glass-card p-3 text-center">
                <div style="font-size: 2.5rem;">📊</div>
                <div class="fw-bold small mt-2">Health Dashboard</div>
              </div>
            </div>
            <div class="col-6">
              <div class="glass-card p-3 text-center">
                <div style="font-size: 2.5rem;">💕</div>
                <div class="fw-bold small mt-2">Compatibility</div>
              </div>
            </div>
            <div class="col-6">
              <div class="glass-card p-3 text-center">
                <div style="font-size: 2.5rem;">👨‍⚕️</div>
                <div class="fw-bold small mt-2">Therapists</div>
              </div>
            </div>
            <div class="col-6">
              <div class="glass-card p-3 text-center">
                <div style="font-size: 2.5rem;">💝</div>
                <div class="fw-bold small mt-2">Memories</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Features Section -->
<section id="features" class="py-5">
  <div class="container">
    <div class="text-center mb-5">
      <span class="badge-glass mb-3 d-inline-block">Platform Modules</span>
      <h2 class="fw-bold display-6">Everything Your Relationship Needs</h2>
      <p class="text-muted" style="max-width: 600px; margin: 0 auto;">
        From AI-powered communication tools to professional therapy — all in one platform.
      </p>
    </div>

    <div class="row g-4">
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon">🤖</div>
          <h3>AI Relationship Assistant</h3>
          <p>Context-aware AI companion analyzing recurring issues and suggesting communication strategies with multiple personas.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon">⚖️</div>
          <h3>AI Conflict Mediator</h3>
          <p>Structured conflict resolution. AI analyzes perspectives without bias, detects emotions, and generates neutral summaries.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon">✏️</div>
          <h3>Conversation Rewriter</h3>
          <p>Rewrites messages to be calmer, more respectful, and emotionally intelligent while preserving your core intent.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon">📊</div>
          <h3>Health Dashboard</h3>
          <p>Track communication scores, trust levels, and conflict trends with interactive charts and monthly reports.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon">💕</div>
          <h3>Compatibility Engine</h3>
          <p>Deep-dive evaluation of financial mindset, lifestyle choices, and parenting philosophy with detailed reports.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon">💰</div>
          <h3>Financial Harmony</h3>
          <p>Shared budgeting, joint expense tracking, and financial personality testing to eliminate money friction.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon">💝</div>
          <h3>Memory Timeline</h3>
          <p>Private social feed with photo uploads, milestone tracking, and automated anniversary reminders.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon">👨‍⚕️</div>
          <h3>Therapist Marketplace</h3>
          <p>Vetted directory of licensed professionals. Filter by specialization, language, and price.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon">📚</div>
          <h3>Growth Programs</h3>
          <p>Structured courses like Trust Rebuilding and Pre-Marriage Prep with interactive lessons and videos.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Pricing Section -->
<section class="py-5">
  <div class="container">
    <div class="text-center mb-5">
      <span class="badge-glass mb-3 d-inline-block">Pricing Plans</span>
      <h2 class="fw-bold display-6">Invest in Your Relationship</h2>
    </div>

    <div class="row g-4 justify-content-center">
      <div class="col-md-4">
        <div class="pricing-card">
          <h4 class="fw-bold mb-1">Free</h4>
          <p class="text-muted small mb-3">Getting started</p>
          <div class="price gradient-text mb-4">$0<small>/mo</small></div>
          <ul class="list-unstyled text-start mb-4">
            <li class="mb-2 small"><i class="bi bi-check-circle-fill text-success me-2"></i>3 AI conversations/month</li>
            <li class="mb-2 small"><i class="bi bi-check-circle-fill text-success me-2"></i>Basic health metrics</li>
            <li class="mb-2 small"><i class="bi bi-check-circle-fill text-success me-2"></i>Memory timeline</li>
            <li class="mb-2 small text-muted"><i class="bi bi-x-circle me-2"></i>Therapist marketplace</li>
            <li class="mb-2 small text-muted"><i class="bi bi-x-circle me-2"></i>Growth programs</li>
          </ul>
          <%= link_to 'Get Started', new_user_registration_path, class: 'btn btn-outline-glass w-100' %>
        </div>
      </div>
      <div class="col-md-4">
        <div class="pricing-card popular">
          <h4 class="fw-bold mb-1">Premium</h4>
