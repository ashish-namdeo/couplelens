          <ul class="list-unstyled text-start mb-4">
            <li class="mb-2 small"><i class="bi bi-check-circle-fill text-success me-2"></i>Unlimited AI conversations</li>
            <li class="mb-2 small"><i class="bi bi-check-circle-fill text-success me-2"></i>Full health analytics</li>
            <li class="mb-2 small"><i class="bi bi-check-circle-fill text-success me-2"></i>Conflict mediator</li>
            <li class="mb-2 small"><i class="bi bi-check-circle-fill text-success me-2"></i>Compatibility assessments</li>
            <li class="mb-2 small"><i class="bi bi-check-circle-fill text-success me-2"></i>Financial tools</li>
          </ul>
          <%= link_to 'Start Free Trial', new_user_registration_path, class: 'btn btn-gradient w-100' %>
        </div>
      </div>
      <div class="col-md-4">
        <div class="pricing-card">
          <h4 class="fw-bold mb-1">Professional</h4>
          <p class="text-muted small mb-3">With therapy</p>
          <div class="price gradient-text mb-4">$49<small>/mo</small></div>
          <ul class="list-unstyled text-start mb-4">
            <li class="mb-2 small"><i class="bi bi-check-circle-fill text-success me-2"></i>Everything in Premium</li>
            <li class="mb-2 small"><i class="bi bi-check-circle-fill text-success me-2"></i>2 therapy sessions/month</li>
            <li class="mb-2 small"><i class="bi bi-check-circle-fill text-success me-2"></i>Priority therapist access</li>
            <li class="mb-2 small"><i class="bi bi-check-circle-fill text-success me-2"></i>Growth programs included</li>
            <li class="mb-2 small"><i class="bi bi-check-circle-fill text-success me-2"></i>Workshop discounts</li>
          </ul>
          <%= link_to 'Contact Sales', new_user_registration_path, class: 'btn btn-outline-glass w-100' %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA Section -->
