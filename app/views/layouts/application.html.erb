<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="CoupleLens - The World's First Relationship Operating System. AI-powered relationship assistance with professional therapist services.">
    <title>CoupleLens — Relationship Operating System</title>

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>

  <body data-controller="toast">
    <%= render 'shared/navbar' %>

    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;">
      <% if notice.present? %>
        <div class="toast show" role="alert" data-controller="toast" data-toast-delay-value="4000" style="background: rgba(26, 26, 46, 0.95); border: 1px solid rgba(108, 99, 255, 0.3); border-radius: 0.75rem;">
          <div class="toast-header" style="background: transparent; border-bottom: 1px solid rgba(108, 99, 255, 0.15); color: #E4E4F0;">
            <i class="bi bi-check-circle-fill me-2" style="color: #2ECC71;"></i>
            <strong class="me-auto" style="color: #E4E4F0;">Success</strong>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
          </div>
          <div class="toast-body" style="color: #C8C8DA;">
            <%= notice %>
          </div>
        </div>
      <% end %>

      <% if alert.present? %>
        <div class="toast show" role="alert" data-controller="toast" data-toast-delay-value="5000" style="background: rgba(26, 26, 46, 0.95); border: 1px solid rgba(108, 99, 255, 0.3); border-radius: 0.75rem;">
          <div class="toast-header" style="background: transparent; border-bottom: 1px solid rgba(108, 99, 255, 0.15); color: #E4E4F0;">
            <i class="bi bi-exclamation-triangle-fill me-2" style="color: #E74C3C;"></i>
            <strong class="me-auto" style="color: #E4E4F0;">Alert</strong>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
          </div>
          <div class="toast-body" style="color: #C8C8DA;">
            <%= alert %>
          </div>
        </div>
      <% end %>
    </div>

    <main>
      <%= yield %>
    </main>

    <% if !user_signed_in? || controller_name == 'pages' %>
      <%= render 'shared/footer' %>
    <% end %>
  </body>
</html>
