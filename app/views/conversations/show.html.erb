<div class="container py-4">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <div class="d-flex align-items-center gap-2">
      <%= link_to conversations_path, class: 'btn btn-sm btn-outline-glass' do %>
        <i class="bi bi-arrow-left"></i>
      <% end %>
      <span style="font-size: 1.5rem;"><%= @conversation.persona_icon %></span>
      <div>
        <h5 class="fw-bold mb-0">
          <%= @conversation.title %>
          <% if @conversation.platform == 'telegram' %>
            <span class="badge ms-1" style="background: rgba(0, 136, 204, 0.15); color: #0088cc; font-size: 0.65rem;">✈️ Telegram</span>
          <% elsif @conversation.platform == 'whatsapp' %>
            <span class="badge ms-1" style="background: rgba(37, 211, 102, 0.15); color: #25D366; font-size: 0.65rem;">📱 WhatsApp</span>
          <% end %>
        </h5>
        <span class="text-muted small"><%= @conversation.persona_display_name %></span>
      </div>
    </div>
  </div>

  <div class="glass-card-static chat-container" data-controller="chat" data-action="click@window->chat#closeEmojiPicker">
    <div class="chat-messages" id="chat-messages" data-chat-target="messages">
      <% @messages.each do |message| %>
        <% case message.role %>
        <% when 'system' %>
          <div class="message-bubble system-message">
            <small><%= message.content.truncate(150) %></small>
          </div>
        <% when 'user' %>
          <div class="message-bubble user-message">
            <div class="small fw-bold mb-1">You</div>
            <%= simple_format(message.content) %>
          </div>
        <% when 'assistant' %>
          <div class="message-bubble assistant-message">
            <div class="small fw-bold mb-1"><%= @conversation.persona_icon %> <%= @conversation.persona_display_name %></div>
            <%= simple_format(message.content) %>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="chat-input-area p-3 border-top border-secondary border-opacity-25" style="background: rgba(15, 14, 23, 0.8);">
      <%= form_with(model: [@conversation, @message], class: 'd-flex align-items-end gap-2', id: 'chat-form', data: { chat_target: 'form', action: 'submit->chat#handleSubmit' }) do |f| %>
        
        <script type="module" src="https://cdn.jsdelivr.net/npm/emoji-picker-element@1/index.js"></script>
        
        <div class="position-relative flex-grow-1 d-flex align-items-center" style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 1.5rem; padding: 0.25rem 0.5rem; transition: background 0.2s;">
          
          <button type="button" id="emoji-button" class="btn btn-link text-muted pe-1 d-flex align-items-center justify-content-center" style="font-size: 1.25rem; text-decoration: none; width: 40px; height: 40px; border-radius: 50%; opacity: 0.7; transition: opacity 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'" data-chat-target="emojiBtn" data-action="click->chat#toggleEmojiPicker">
            😀
          </button>
          
          <%= f.text_area :content, id: 'chat-input', class: 'form-control border-0 shadow-none bg-transparent text-white focus-ring focus-ring-dark', placeholder: @conversation.language == 'hindi' ? 'अपना संदेश लिखें...' : 'Type your message...', rows: 1, style: 'resize: none; max-height: 120px; outline: none; box-shadow: none;', data: { chat_target: 'input', action: 'input->chat#resizeInput keydown->chat#handleKeydown' } %>
          
          <!-- Emoji picker hidden by default -->
          <div id="emoji-picker-container" style="display: none; position: absolute; bottom: calc(100% + 15px); left: 0; z-index: 1000; filter: drop-shadow(0 10px 25px rgba(0,0,0,0.5)); border-radius: 10px;" data-chat-target="pickerContainer">
            <emoji-picker class="dark" style="--background: #1A1A2E; --border-color: rgba(255,255,255,0.1); --input-border-color: rgba(255,255,255,0.2); --text-color: #fff;" data-chat-target="picker" data-action="emoji-click->chat#handleEmojiClick"></emoji-picker>
          </div>
        </div>

        <button type="submit" class="btn btn-gradient rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 shadow-sm" id="send-button" style="width: 48px; height: 48px; transition: transform 0.2s;" onmousedown="this.style.transform='scale(0.95)'" onmouseup="this.style.transform='scale(1)'" data-chat-target="sendBtn">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="white" style="transform: translateX(2px);">
            <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"></path>
          </svg>
        </button>
      <% end %>
    </div>
  </div>
</div>
