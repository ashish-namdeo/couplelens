<div class="container py-4">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <div class="d-flex align-items-center gap-2">
      <%= link_to conversations_path, class: 'btn btn-sm btn-outline-glass' do %>
        <i class="bi bi-arrow-left"></i>
      <% end %>
      <span style="font-size: 1.5rem;"><%= @conversation.persona_icon %></span>
      <div>
        <h5 class="fw-bold mb-0"><%= @conversation.title %></h5>
        <span class="text-muted small"><%= @conversation.persona_display_name %></span>
      </div>
    </div>
  </div>

  <div class="glass-card-static chat-container">
    <div class="chat-messages" id="chat-messages">
      <% @messages.each do |message| %>
        <% case message.role %>
        <% when 'system' %>
          <div class="message-bubble system-message">
            <small><%= message.content.truncate(150) %></small>
          </div>
        <% when 'user' %>
          <div class="message-bubble user-message">
            <div class="small fw-bold mb-1">You</div>
            <%= simple_format(message.content) %>
          </div>
        <% when 'assistant' %>
          <div class="message-bubble assistant-message">
            <div class="small fw-bold mb-1"><%= @conversation.persona_icon %> <%= @conversation.persona_display_name %></div>
            <%= simple_format(message.content) %>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="chat-input-area">
      <%= form_with(model: [@conversation, @message], class: 'd-flex gap-2') do |f| %>
        <%= f.text_area :content, class: 'form-control', placeholder: 'Type your message...', rows: 1, style: 'resize: none;' %>
        <%= f.submit 'Send', class: 'btn btn-gradient px-4' %>
      <% end %>
    </div>
  </div>
</div>

<script>
  // Auto-scroll to bottom of chat
  document.addEventListener('DOMContentLoaded', function() {
    const chatMessages = document.getElementById('chat-messages');
    if (chatMessages) {
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }
  });
</script>
