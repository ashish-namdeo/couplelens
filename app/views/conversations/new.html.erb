<div class="container py-4">
  <div class="page-header">
    <h1>✨ Start New <span class="gradient-text">Conversation</span></h1>
    <p>Choose your companion persona</p>
  </div>

  <%= form_with(model: @conversation, class: 'animate-fade-in') do |f| %>
    <div class="glass-card-static p-4 mb-4">
      <div class="mb-4">
        <%= f.label :title, class: 'form-label' do %>
          Conversation Topic <span class="text-danger">*</span>
        <% end %>
        <div class="position-relative">
          <%= f.text_field :title, class: 'form-control', placeholder: 'e.g., Communication challenges with my partner', id: 'conversation-topic' %>
          <div id="topic-tooltip" style="display: none; position: absolute; top: calc(100% + 4px); left: 0; background: rgba(231, 76, 60, 0.95); color: #fff; padding: 0.35rem 0.6rem; border-radius: 0.4rem; font-size: 0.8rem; z-index: 10; white-space: nowrap;">
            Please enter a conversation topic
          </div>
        </div>
        <div class="form-text" style="color: #aaa;" id="topic-hint">Please describe what you'd like to discuss</div>
      </div>

      <label class="form-label">Select AI Persona</label>
      <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
          <label class="persona-card d-block">
            <%= f.radio_button :persona, 'clinical_psychologist', class: 'd-none' %>
            <div class="persona-emoji">🧠</div>
            <h5>Clinical Psychologist</h5>
            <p>Evidence-based insights & attachment theory</p>
          </label>
        </div>
        <div class="col-md-3 col-6">
          <label class="persona-card d-block">
            <%= f.radio_button :persona, 'empathetic_listener', checked: true, class: 'd-none' %>
            <div class="persona-emoji">💝</div>
            <h5>Empathetic Listener</h5>
            <p>Emotional validation & safe space</p>
          </label>
        </div>
        <div class="col-md-3 col-6">
          <label class="persona-card d-block">
            <%= f.radio_button :persona, 'relationship_coach', class: 'd-none' %>
            <div class="persona-emoji">🎯</div>
            <h5>Relationship Coach</h5>
            <p>Actionable strategies & accountability</p>
          </label>
        </div>
        <div class="col-md-3 col-6">
          <label class="persona-card d-block">
            <%= f.radio_button :persona, 'communication_expert', class: 'd-none' %>
            <div class="persona-emoji">💬</div>
            <h5>Communication Expert</h5>
            <p>Language patterns & NVC techniques</p>
          </label>
        </div>
      </div>
    </div>

    <div class="glass-card-static p-4 mb-4">
      <label class="form-label">Select Language / भाषा चुनें</label>
      <div class="row g-3">
        <div class="col-md-6 col-6">
          <label class="persona-card d-block">
            <%= f.radio_button :language, 'english', checked: true, class: 'd-none' %>
            <div class="persona-emoji">🇬🇧</div>
            <h5>English</h5>
          </label>
        </div>
        <div class="col-md-6 col-6">
          <label class="persona-card d-block">
            <%= f.radio_button :language, 'hindi', class: 'd-none' %>
            <div class="persona-emoji">🇮🇳</div>
            <h5>हिन्दी (Hindi)</h5>
          </label>
        </div>
      </div>
    </div>

    <div class="d-flex gap-3">
      <%= f.submit 'Start Conversation', class: 'btn btn-gradient btn-lg' %>
      <%= link_to 'Cancel', 'javascript:history.back()', class: 'btn btn-outline-glass btn-lg' %>
    </div>
  <% end %>
</div>

<script>
document.addEventListener('turbo:load', function() {
  const form = document.querySelector('form');
  const topicInput = document.getElementById('conversation-topic');
  const topicTooltip = document.getElementById('topic-tooltip');
  const topicHint = document.getElementById('topic-hint');

  if (!form || !topicInput || !topicTooltip) return;

  // Remove previous handlers to prevent duplicates on Turbo navigation
  if (form._validateTopic) {
    form.removeEventListener('submit', form._validateTopic);
  }

  form._validateTopic = function(e) {
    if (topicInput.value.trim() === '') {
      e.preventDefault();
      topicInput.style.borderColor = '#E74C3C';
      topicInput.style.boxShadow = '0 0 0 0.15rem rgba(231, 76, 60, 0.25)';
      topicTooltip.style.display = 'block';
      if (topicHint) topicHint.style.display = 'none';
      topicInput.focus();
    } else {
      topicInput.style.borderColor = '';
      topicInput.style.boxShadow = '';
      topicTooltip.style.display = 'none';
      if (topicHint) topicHint.style.display = '';
    }
  };

  form.addEventListener('submit', form._validateTopic);

  topicInput.addEventListener('input', function() {
    if (topicInput.value.trim() !== '') {
      topicInput.style.borderColor = '';
      topicInput.style.boxShadow = '';
      topicTooltip.style.display = 'none';
      if (topicHint) topicHint.style.display = '';
    }
  });
});
</script>
