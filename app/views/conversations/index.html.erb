<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div class="page-header mb-0">
      <h1>🤖 AI <span class="gradient-text">Assistant</span></h1>
      <p>Your personal relationship companion</p>
    </div>
    <%= link_to new_conversation_path, class: 'btn btn-gradient' do %>
      <span><i class="bi bi-plus-lg me-1"></i> New Conversation</span>
    <% end %>
  </div>

  <% if @conversations.any? %>
    <div class="row g-3">
      <% @conversations.each do |conv| %>
        <div class="col-md-6 col-lg-4 animate-fade-in-up">
          <div class="glass-card p-4 h-100">
            <div class="d-flex align-items-start justify-content-between mb-3">
              <span style="font-size: 2rem;"><%= conv.persona_icon %></span>
              <span class="badge-glass"><%= conv.persona_display_name %></span>
            </div>
            <h5 class="fw-bold mb-2"><%= conv.title %></h5>
            <p class="text-muted small mb-3">
              <%= conv.messages.count %> messages · Updated <%= time_ago_in_words(conv.updated_at) %> ago
            </p>
            <div class="d-flex gap-2">
              <%= link_to 'Continue', conv, class: 'btn btn-sm btn-gradient flex-grow-1' %>
              <%= link_to 'Delete', conv, method: :delete, data: { confirm: 'Delete this conversation?' }, class: 'btn btn-sm btn-outline-glass' %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="glass-card-static p-5">
      <div class="empty-state">
        <div class="empty-icon">💬</div>
        <h3>No conversations yet</h3>
        <p>Start your first AI-powered relationship conversation. Choose a persona that fits your needs.</p>
        <%= link_to new_conversation_path, class: 'btn btn-gradient mt-3' do %>
          <span>Start Your First Chat</span>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
